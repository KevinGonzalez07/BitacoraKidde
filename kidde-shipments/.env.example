# ─── Supabase / PostgreSQL ───────────────────────────────────────────────────
#
# Encuentra estos valores en:
#   Supabase Dashboard → tu proyecto → Settings → Database → Connection string
#
# Usa la URI de "Transaction pooler" (puerto 6543) para el cliente Prisma
# y la URI de "Session mode" (puerto 5432) para las migraciones.
#
# Formato:
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.pnxgohafpdzdgsikwmto:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.pnxgohafpdzdgsikwmto:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# ─── Cron ────────────────────────────────────────────────────────────────────
CRON_SECRET="your-cron-secret-here"
